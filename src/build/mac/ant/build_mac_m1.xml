    <target name="jlink-runtime-image" depends="clean-runtime-image">
        <echo message="Creating custom runtime image at: ${runtime_image}"/>

        <exec executable="${jlink_executable}" failonerror="true">
            <arg value="--module-path"/>
            <arg value="${jdk.home}/jmods:/Users/thomasschmidt/Dropbox/EXMARaLDA_Build/2025-11-25_JAVA_FX_25/MAC-M1/javafx-sdk-21.0.9/lib"/>

