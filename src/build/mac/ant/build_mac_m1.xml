        </exec>    
       
    </target>

    
    <target name="DEBUG" depends="embed-app-in-runtime">
      
        
        <echo message="JPACKAGING FOLKER"/>
        <echo message="Entitlements file: ${entitlements_plist}"/>
        <available file="${entitlements_plist}" property="entitlements.exists"/>
        <echo message="Entitlements exists: ${entitlements.exists}"/>
       
        <!-- FOLKER -->
        <exec executable="${jpackage_excecutable}">
            
            <arg value="--verbose"/>
            
            <arg value="--type"/>
            <arg value="dmg"/>
            <arg value="--resource-dir"/><arg value="${icons_folder}"/>
                        
            <!-- -->
            
                        
            <arg value="--input"/><arg value="${jpackage_input}"/>
            <arg value="--dest"/><arg value="${jpackage_target}/FOLKER_DMG"/>
            <arg value="--main-jar"/><arg value="exmaralda_nb.jar"/>
            <arg value="--java-options"/><arg value="-Djava.library.path=$ROOTDIR/Contents/app/native"/>
            <arg value="--java-options"/><arg value="-Dapple.laf.useScreenMenuBar=true"/>
            <arg value="--java-options"/><arg value="--enable-native-access=ALL-UNNAMED"/>            
            <!-- -->
            <arg value="--java-options"/><arg value="-Dcom.apple.mrj.application.apple.menu.about.name=FOLKER"/>
            <arg value="--main-class"/><arg value="org.exmaralda.folker.application.ApplicationFrame"/>
            <arg value="--app-version"/><arg value="${folker_version}"/>
            <arg value="--name"/><arg value="FOLKER"/>
            <arg value="--mac-package-name"/><arg value="FOLKER"/>
            <arg value="--mac-package-identifier"/><arg value="org.exmaralda.folker"/>
            <arg value="--file-associations"/><arg value="${file_ass_folder}/folker_file_ass.properties"/>

            <arg value="--runtime-image"/><arg value="${runtime_image}"/>           
            <!--  SIGNING -->
            <arg value="--mac-sign"/>
            <arg value="--mac-signing-key-user-name"/><arg value="Developer ID Application: Thomas Schmidt (YXGNP3T9KU)"/>
            <arg value="--mac-entitlements"/><arg value="${entitlements_plist}"/>
        </exec>    
        
        <echo message="MOUNTING"/>
        <exec executable="hdiutil">
            <arg value="attach"/>
            <arg value="${jpackage_target}/FOLKER_DMG/FOLKER-1.3.3.dmg"/>
            <arg value="-nobrowse"/>
            <arg value="-mountpoint"/>
            <arg value="/tmp/FOLKER_mount"/>
        </exec>        
        
        <!-- 1. Copy app to writable temp location (preserves signature) -->
        <exec executable="cp">
            <arg value="-R"/>
            <arg value="/tmp/FOLKER_mount/FOLKER.app"/>
            <arg value="${jpackage_target}/FOLKER_unsigned.app"/>
        </exec>        
        
        <!-- 2. Remove existing signature from launcher only -->
        <echo message="REMOVE SIGNATURE"/>
        <exec executable="codesign">
            <arg value="--remove-signature"/>
            <arg value="${jpackage_target}/FOLKER_unsigned.app/Contents/MacOS/FOLKER"/>
        </exec>

        <echo message="SEPARATE CODESIGNING"/>
        <exec executable="codesign">
            <arg value="-f"/>
            <arg value="--entitlements"/>
            <arg value="${entitlements_plist}"/>
            <arg value="-s"/>
            <arg value="BBCEF8F6E23C201A25A7ABBF1DE1762F34DE9F1E"/>
            <arg value="--options"/>
            <arg value="runtime"/>
            <arg value="${jpackage_target}/FOLKER_unsigned.app/Contents/MacOS/FOLKER"/>
            
        </exec>

        <echo message="VERIFYING CODESIGNING"/>
        <!-- Verify it worked -->
        <exec executable="codesign">
            <arg value="-d"/>
            <arg value="--entitlements"/>
            <arg value="-"/>
            <arg value="--xml"/>
            <arg value="${jpackage_target}/FOLKER_unsigned.app/Contents/MacOS/FOLKER"/>
        </exec>        
        
        <!-- Eject -->
        <echo message="EJECTING"/>
        <exec executable="hdiutil">
            <arg value="detach"/>
            <arg value="/tmp/FOLKER_mount"/>
        </exec>        
    </target>
    
    <target name="embed-app-in-runtime" depends="prepare_jpackage, jlink-runtime-image">
        <echo message="Copying app jars and native libraries into runtime image..."/>

        <!-- Create directories inside runtime image -->
        <mkdir dir="${runtime_image}/lib"/>
        <mkdir dir="${runtime_image}/native"/>

        <!-- Copy all jars from your app/lib -->
        <copy todir="${runtime_image}/lib" flatten="true">
            <fileset dir="${jpackage_input}" includes="**/*.jar"/>
        </copy>

        <!-- Copy all native libraries -->
        <copy todir="${runtime_image}/native" flatten="true">
            <fileset dir="${jpackage_source}/native" includes="**/*.dylib"/>
        </copy>


        <echo message="App successfully embedded into runtime image."/>
    </target>

    
    
    

            
</project>


