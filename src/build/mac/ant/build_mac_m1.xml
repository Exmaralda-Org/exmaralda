            <arg value="--output"/>
            <arg value="${runtime_image}"/>

            <!-- optional optimization flags -->
            <arg value="--strip-debug"/>
            <arg value="--no-header-files"/>
            <arg value="--no-man-pages"/>

        </exec>

        <echo message="Runtime image created successfully."/>
    </target>
        
    

